{
  "manifest_version": 3,
  "name": "NoMoreOneMore",
  "version": "0.1",
  "browser_specific_settings": {
    "gecko": {
      "id": "@no-more-one-more",
      "data_collection_permissions": {
        "required": ["none"]
      }
    }
  },
  "description": "Adds friction after an episode ends.",
  "permissions": ["activeTab", "storage"],
  "host_permissions": ["*://*.netflix.com/*"],
  "content_scripts": [
    {
      "matches": ["*://*.netflix.com/*"],
      "js": ["content.js"],
      "run_at": "document_end"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Settings"
  }
}

